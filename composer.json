{
    "name": "symfinity/ux-blocks-interactive",
    "description": "Symfinity UX Blocks Interactive — client stl tier with blocks.int fragments",
    "license": "MIT",
    "type": "symfony-bundle",
    "require": {
        "php": ">=8.2",
        "symfinity/ux-blocks-extended": "@dev",
        "symfony/asset-mapper": "^7.4||^8.0",
        "symfony/framework-bundle": "^7.4||^8.0",
        "symfony/twig-bundle": "^7.4||^8.0",
        "symfony/stimulus-bundle": "^2.0|^3.0",
        "symfony/ux-twig-component": "^2.0|^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0",
        "symfinity/ux-blocks": "@dev",
        "symfony/browser-kit": "^7.4||^8.0",
        "symfony/css-selector": "^7.4||^8.0",
        "symfony/http-client": "^7.4||^8.0",
        "symfony/yaml": "^7.4||^8.0"
    },
    "suggest": {
        "symfinity/ui-kernel": "SchemeSwitch enhanced mode (PATCH /_ui/theme/scheme) and theme shell view-model",
        "symfinity/ux-runtime": "Optional command palette JSON backend (blocks.int.command-palette)"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../ux-blocks-extended",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "../ux-blocks",
            "options": { "symlink": true }
        }
    ],
    "autoload": {
        "psr-4": {
            "Symfinity\\UxBlocksInteractive\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Symfinity\\UxBlocksInteractive\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit -c phpunit.xml.dist"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "version": "0.1.0-dev",
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    }
}
