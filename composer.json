{
    "name": "symfinity/ux-blocks-interactive",
    "description": "Stimulus-backed interactive widgets",
    "license": "MIT",
    "type": "symfony-bundle",
    "homepage": "https://github.com/symfinity/ux-blocks-interactive",
    "support": {
        "issues": "https://github.com/symfinity/ux-blocks-interactive/issues",
        "source": "https://github.com/symfinity/ux-blocks-interactive",
        "docs": "https://docs.symfinity.dev/ux-blocks-interactive"
    },
    "authors": [
        {
            "name": "Symfinity",
            "email": "dev@symfinity.net",
            "homepage": "https://symfinity.net/"
        }
    ],
    "keywords": [
        "symfony",
        "symfony-bundle",
        "symfony-ux",
        "twig-components",
        "ux-blocks",
        "design-system",
        "stimulus",
        "interactive"
    ],
    "require": {
        "php": ">=8.2",
        "symfinity/ux-blocks-extended": "^0.1",
        "symfinity/ux-blocks-form": "^0.1",
        "symfony/asset-mapper": "^7.4||^8.0",
        "symfony/framework-bundle": "^7.4||^8.0",
        "symfony/twig-bundle": "^7.4||^8.0",
        "symfony/stimulus-bundle": "^2.0|^3.0",
        "symfony/ux-twig-component": "^2.0|^3.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-symfony": "^2.0",
        "phpunit/phpunit": "^10.5 || ^11.0",
        "symfinity/ui-kernel": "^0.1",
        "symfinity/ux-blocks": "^0.1.3 || 0.1.x-dev@dev",
        "symfony/browser-kit": "^7.4||^8.0",
        "symfony/css-selector": "^7.4||^8.0",
        "symfony/http-client": "^7.4||^8.0",
        "symfony/yaml": "^7.4||^8.0"
    },
    "suggest": {
        "symfinity/ux-runtime": "Optional command palette JSON backend (blocks.int.command-palette)"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../ux-blocks-core",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "../ux-blocks-extended",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "../ux-blocks-form",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "../ux-blocks",
            "options": { "symlink": true }
        },
        {
            "type": "path",
            "url": "../ui-kernel",
            "options": { "symlink": true }
        }
    ],
    "autoload": {
        "psr-4": {
            "Symfinity\\UxBlocksInteractive\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Symfinity\\UxBlocksInteractive\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit -c phpunit.xml.dist",
        "phpstan": "phpstan analyse --memory-limit=512M"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "version": "0.1.0-dev",
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        },
        "symfony": {
            "require": "^7.4||^8.0"
        }
    }
}
