<div
    data-ui-role="calendar"
    data-ui-fragment="blocks.int.calendar"
    data-controller="symfony--ux-blocks-interactive--calendar"
    {{ attributes }}
>
    <div data-ui-part="nav" style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.5rem;">
        <button
            type="button"
            data-ui-role="calendar-prev"
            data-action="click->symfony--ux-blocks-interactive--calendar#previousMonth"
        >
            Previous
        </button>
        <span data-symfony--ux-blocks-interactive--calendar-target="label" aria-live="polite"></span>
        <button
            type="button"
            data-ui-role="calendar-next"
            data-action="click->symfony--ux-blocks-interactive--calendar#nextMonth"
        >
            Next
        </button>
    </div>
    <div data-ui-part="grid" data-symfony--ux-blocks-interactive--calendar-target="grid"></div>
    {% block content %}{% endblock %}
</div>
