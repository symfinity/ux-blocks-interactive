<div
    data-ui-role="collapsible"
    data-ui-fragment="blocks.int.collapsible"
    data-ui-state="{{ collapsible_is_open ? 'open' : 'closed' }}"
    data-controller="symfinity--ux-blocks-core--collapsible"
    data-symfinity--ux-blocks-core--collapsible-open-value="{{ collapsible_is_open ? 'true' : 'false' }}"
    data-symfinity--ux-blocks-core--collapsible-content-id-value="{{ collapsible_content_id }}"
    data-symfinity--ux-blocks-core--collapsible-disabled-value="{{ collapsible_disabled ? 'true' : 'false' }}"
    {{ attributes }}
>
    {% block content %}{% endblock %}
</div>
