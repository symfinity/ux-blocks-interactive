<button
    type="button"
    role="menuitem"
    aria-haspopup="true"
    aria-expanded="false"
    data-ui-role="menubar-trigger"
    data-action="click->symfony--ux-blocks-interactive--menubar#toggle"
    data-symfony--ux-blocks-interactive--menubar-target="trigger"
    {{ attributes }}
>
    {% block content %}{% endblock %}
</button>
