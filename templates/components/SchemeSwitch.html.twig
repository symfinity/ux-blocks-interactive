{% set isDark = colorScheme == 'dark' %}
{% set ariaLabel = label|default('Color scheme') %}
{% set lightUrl = '' %}
{% set darkUrl = '' %}
{% for link in links %}
    {% if link.scheme == 'light' %}
        {% set lightUrl = link.url %}
    {% endif %}
    {% if link.scheme == 'dark' %}
        {% set darkUrl = link.url %}
    {% endif %}
{% endfor %}

{% if enhanced %}
    {% set switchAttributes = attributes.defaults({
        'data-controller': 'symfinity--ux-blocks-interactive--scheme-switch',
        'data-symfinity--ux-blocks-interactive--scheme-switch-scheme-value': scheme,
        'data-symfinity--ux-blocks-interactive--scheme-switch-endpoint-value': schemeEndpoint,
        'data-symfinity--ux-blocks-interactive--scheme-switch-color-scheme-value': colorScheme,
        'data-action': 'change->symfinity--ux-blocks-interactive--scheme-switch#toggle',
        'data-scheme-light-url': lightUrl,
        'data-scheme-dark-url': darkUrl,
    }) %}
{% else %}
    {% set switchAttributes = attributes.defaults({
        onchange: "(function (el) { var url = el.checked ? el.dataset.schemeDarkUrl : el.dataset.schemeLightUrl; if (url) { window.location.href = url; } else { el.checked = !el.checked; } })(this)",
        'data-scheme-light-url': lightUrl,
        'data-scheme-dark-url': darkUrl,
    }) %}
{% endif %}

<span
    data-ui-role="scheme-switch"
    data-ui-part="scheme-switch-chrome"
    data-scheme-switch-state="{{ isDark ? 'dark' : 'light' }}"
>
    <input
        type="checkbox"
        role="switch"
        data-ui-role="switch"
        data-ui-fragment="blocks.int.scheme-switch"
        data-ui-variant="ghost"
        aria-label="{{ ariaLabel }}"
        {% if isDark %}checked{% endif %}
        {% if disabled %}disabled data-ui-state="disabled"{% endif %}
        {{ switchAttributes }}
    />
    <span data-ui-part="scheme-switch-icon" data-scheme-switch-icon="sun" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"/>
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
        </svg>
    </span>
    <span data-ui-part="scheme-switch-icon" data-scheme-switch-icon="moon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 14.5A8.5 8.5 0 0 1 9.5 3 7 7 0 1 0 21 14.5z"/>
        </svg>
    </span>
</span>
